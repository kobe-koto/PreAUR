# yaml-language-server: $schema=https://raw.githubusercontent.com/kobe-koto/PreAUR/main/preaur.schema.json

# Packager: PreAUR (on behalf of NAME) <EMAIL>
config:
  # PKGBUILD version parser backend:
  # "native" -> fast built-in parser with bash expansion fallback (default)
  # "makepkg" -> use `makepkg --printsrcinfo` for makepkg-compatible parsing
  pkgbuildParser: "native"
  # Extra git URL prefixes that should still be treated as trusted AUR mirrors
  # for ownership checks. Built-ins:
  # - ssh://aur@aur.archlinux.org/
  # - https://aur.archlinux.org/
  # trustedAurGitPrefixes:
  #   - "https://aur-mirror.example.org/"

maintainers:
  - id: "johndoe"
    name: "John Doe"
    email: "john.doe@example.com"

resources:
  # Controls $MAKEFLAGS internally
  # "-2" -> uses (total_cores - 2)
  # "-1" -> uses (total_cores - 1) - default logic if omitted
  # "--all" -> uses all logical cores
  # "4" -> explicitly use 4 cores
  cpu: "-2" 
  parallel: 2

repo:
  # Defines the local output registry name
  # Resulting structure inside `repo/myrepo/` will include `myrepo.db.tar.gz` and copied `.pkg.tar.zst` files 
  name: "myrepo" 

packages:
  # If an AUR package is orphaned, PreAUR skips its build unless this is set
  # on that package:
  # allow_orphan_package_build: true
  #
  # If `git` points at a trusted AUR prefix, PreAUR derives the AUR name from
  # the URL. Use aur_pkgname when the AUR name needs to be explicit:
  # aur_pkgname: "upstream-aur-name"

  # Standard Github release mapped package
  - pkgname: "grub-theme-lain"
    maintainer: "johndoe"
    checker:
      type: "github" # Version query provider
      repo: "uiriansan/LainGrubTheme"
      use: "release" # Set to 'prerelease' if using beta tags
      # prefix: "app-release-" # remove prefix if not needed
      # suffix: "_beta" # remove suffix if not needed
      normalize: true # replace colons :, forward slashes /, hyphens -, or whitespaces with underscores
    push: true # Automatically git commit and push back to AUR on success
    builder: "extra-x86_64-build" # Specific build executable. Can use "pkgctl build" if preferred! Defaults to extra-x86_64-build
    dummy_packages:
      - dummy: "grub" # this result in a `grub-dummy` pkg provides "grub"
        epoch: 2
        pkgver: 2.14
        pkgrel: 1
        files:
         - /usr/bin/grub # this would be a copy of /dev/null

  # Git/Dynamic Versioning mapped package
  - pkgname: "grub-theme-lobo-git"
    maintainer: "johndoe"
    # Notice: No checker is needed here.
    # preaur automatically detects the `pkgver()` bash block
    # and invokes `makepkg -odc` to pull the latest commits and dynamically set the package version.
    dummy_packages:
      - dummy: "grub" # this result in a `grub-dummy` pkg provides "grub"
        epoch: 2
        pkgver: 2.14
        pkgrel: 1
        files:
         - /usr/bin/grub # this would be a copy of /dev/null
    repo_packages: # packages that in this repo, and should be installed before build this package
      - grub-theme-lain

  # Debian/APT repository mapped package
  - pkgname: "visual-studio-code-bin"
    maintainer: "johndoe"
    checker:
      type: "deb"
      strip_version: true # no pkgrel will be passed
      url: "https://packages.microsoft.com/repos/vscode"
      dist: "stable"
      component: "main"
      arch: "amd64"
      pkg: "code"

  # RPM/Yum repository mapped package example
  - pkgname: "visual-studio-code-electron-bin"
    maintainer: "johndoe"
    checker:
      type: "rpm"
      strip_version: true # no pkgrel will be passed
      url: "https://packages.microsoft.com/yumrepos/vscode"
      pkg: "code"

  - pkgname: spotify
    maintainer: johndoe
    checker:
      type: deb  
      strip_version: false
      template: '{~pkgver}.{~pkgver}.{~pkgver}.{~pkgver}.{_commit}'
      url: 'https://repository.spotify.com'
      dist: testing 
      component: non-free
      arch: amd64
      pkg: spotify-client
