{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "maintainers": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Stable maintainer id used by packages."
                    },
                    "name": {
                        "type": "string",
                        "description": "Maintainer display name."
                    },
                    "email": {
                        "type": "string",
                        "description": "Maintainer email address."
                    }
                },
                "required": [
                    "id",
                    "name",
                    "email"
                ],
                "additionalProperties": false,
                "description": "A packager identity."
            },
            "description": "Known PreAUR maintainers."
        },
        "default_maintainer": {
            "description": "Maintainer id used when a package omits maintainer.",
            "type": "string"
        },
        "git": {
            "description": "Project repository automation.",
            "default": {},
            "type": "object",
            "properties": {
                "enabled": {
                    "default": true,
                    "description": "Enable project git automation.",
                    "type": "boolean"
                },
                "remote": {
                    "default": "origin",
                    "description": "Remote used for sync and push.",
                    "type": "string"
                },
                "branch": {
                    "description": "Branch used for sync and push. Default: current branch.",
                    "type": "string"
                },
                "sync": {
                    "description": "Project git startup sync policy.",
                    "default": {},
                    "type": "object",
                    "properties": {
                        "allow_remote_overwrite_local": {
                            "default": false,
                            "description": "Reset local state to remote during sync.",
                            "type": "boolean"
                        },
                        "allowRemoteOverwriteLocal": {
                            "description": "CamelCase alias for allow_remote_overwrite_local.",
                            "type": "boolean"
                        }
                    },
                    "additionalProperties": false
                },
                "push": {
                    "description": "Project git push policy.",
                    "default": {},
                    "type": "object",
                    "properties": {
                        "force": {
                            "default": false,
                            "description": "Use git push --force after builds.",
                            "type": "boolean"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "config": {
            "type": "object",
            "properties": {
                "pkgbuildParser": {
                    "description": "PKGBUILD parser implementation.",
                    "type": "string",
                    "enum": [
                        "native",
                        "makepkg"
                    ]
                },
                "trustedAurGitPrefixes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Git URL prefixes treated as AUR package sources."
                },
                "pkgbuildSandbox": {
                    "description": "Chroot sandbox used for PKGBUILD metadata commands before building.",
                    "default": {},
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "default": true,
                            "description": "Run PKGBUILD metadata commands inside a chroot sandbox.",
                            "type": "boolean"
                        },
                        "root": {
                            "description": "Chroot root directory. Defaults to the devtools root derived from the package builder.",
                            "type": "string"
                        },
                        "command": {
                            "default": "systemd-nspawn",
                            "description": "Sandbox command used to enter the chroot.",
                            "type": "string"
                        },
                        "sudo": {
                            "default": true,
                            "description": "Run the sandbox command through sudo when PreAUR is not root.",
                            "type": "boolean"
                        },
                        "user": {
                            "default": "preaur",
                            "description": "User used inside the chroot for makepkg commands. It is created with the host UID when missing.",
                            "type": "string"
                        },
                        "network": {
                            "default": true,
                            "description": "Allow network access inside the PKGBUILD sandbox.",
                            "type": "boolean"
                        },
                        "ephemeral": {
                            "default": true,
                            "description": "Run metadata commands in a temporary chroot copy that is discarded after the command exits.",
                            "type": "boolean"
                        },
                        "initRoot": {
                            "default": true,
                            "description": "Initialize a missing chroot root by running the package builder on a generated safe package.",
                            "type": "boolean"
                        },
                        "packages": {
                            "default": [],
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Extra packages installed in the temporary metadata chroot before running PKGBUILD commands."
                        }
                    },
                    "additionalProperties": false
                },
                "chrootPacman": {
                    "type": "object",
                    "properties": {
                        "include": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Host files included into generated pacman.conf."
                        },
                        "lines": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Raw pacman.conf lines appended globally."
                        },
                        "repositories": {
                            "description": "Custom chroot pacman repositories.",
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "description": "Pacman repository name."
                                    },
                                    "siglevel": {
                                        "description": "Repository SigLevel line.",
                                        "anyOf": [
                                            {
                                                "type": "string"
                                            },
                                            {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        ]
                                    },
                                    "include": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "Host files included into this repository block."
                                    },
                                    "lines": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "Raw pacman.conf lines appended to this repository block."
                                    }
                                },
                                "required": [
                                    "name"
                                ],
                                "additionalProperties": false,
                                "description": "A custom pacman repository for chroot builds."
                            }
                        }
                    },
                    "additionalProperties": false,
                    "description": "Pacman configuration added to devtools chroots."
                }
            },
            "additionalProperties": false,
            "description": "Runtime behavior settings."
        },
        "resources": {
            "description": "Build and check concurrency settings.",
            "default": {},
            "type": "object",
            "properties": {
                "cpu": {
                    "description": "CPU allocation passed to builders.",
                    "type": "string"
                },
                "parallel": {
                    "default": 2,
                    "description": "Concurrent package builds.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 9007199254740991
                },
                "updateCheckCocurrent": {
                    "default": 1,
                    "description": "Concurrent version checks.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 9007199254740991
                }
            },
            "additionalProperties": false
        },
        "repo": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Local pacman repository name."
                }
            },
            "required": [
                "name"
            ],
            "additionalProperties": false,
            "description": "Local pacman repository settings."
        },
        "packages": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "pkgname": {
                        "type": "string",
                        "description": "Local package name."
                    },
                    "maintainer": {
                        "description": "Maintainer id. Defaults to default_maintainer.",
                        "type": "string"
                    },
                    "allow_orphan_package_build": {
                        "description": "Allow building an orphan AUR package.",
                        "type": "boolean"
                    },
                    "aur_pkgname": {
                        "description": "AUR package name when it differs from pkgname.",
                        "type": "string"
                    },
                    "git": {
                        "description": "Package PKGBUILD git URL override.",
                        "type": "string"
                    },
                    "checker": {
                        "oneOf": [
                            {
                                "type": "object",
                                "properties": {
                                    "strip_version": {
                                        "description": "Strip common version prefixes before comparison.",
                                        "type": "boolean"
                                    },
                                    "normalize": {
                                        "description": "Normalize upstream version text.",
                                        "type": "boolean"
                                    },
                                    "template": {
                                        "description": "Template mapping upstream version text to PKGBUILD variables.",
                                        "type": "string"
                                    },
                                    "type": {
                                        "type": "string",
                                        "const": "github",
                                        "description": "Use GitHub release data."
                                    },
                                    "repo": {
                                        "type": "string",
                                        "description": "GitHub repository as owner/name."
                                    },
                                    "use": {
                                        "description": "Release selector such as release or prerelease.",
                                        "type": "string"
                                    },
                                    "prefix": {
                                        "description": "Version tag prefix to strip.",
                                        "type": "string"
                                    },
                                    "suffix": {
                                        "description": "Version tag suffix to strip.",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "type",
                                    "repo"
                                ],
                                "additionalProperties": false,
                                "description": "GitHub version checker."
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "strip_version": {
                                        "description": "Strip common version prefixes before comparison.",
                                        "type": "boolean"
                                    },
                                    "normalize": {
                                        "description": "Normalize upstream version text.",
                                        "type": "boolean"
                                    },
                                    "template": {
                                        "description": "Template mapping upstream version text to PKGBUILD variables.",
                                        "type": "string"
                                    },
                                    "type": {
                                        "type": "string",
                                        "const": "deb",
                                        "description": "Use a Debian Packages index."
                                    },
                                    "url": {
                                        "type": "string",
                                        "description": "Repository base URL."
                                    },
                                    "pkg": {
                                        "type": "string",
                                        "description": "Debian package name."
                                    },
                                    "dist": {
                                        "type": "string",
                                        "description": "Debian distribution name."
                                    },
                                    "component": {
                                        "type": "string",
                                        "description": "Debian repository component."
                                    },
                                    "arch": {
                                        "description": "Debian architecture.",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "type",
                                    "url",
                                    "pkg",
                                    "dist",
                                    "component"
                                ],
                                "additionalProperties": false,
                                "description": "Debian repository version checker."
                            },
                            {
                                "type": "object",
                                "properties": {
                                    "strip_version": {
                                        "description": "Strip common version prefixes before comparison.",
                                        "type": "boolean"
                                    },
                                    "normalize": {
                                        "description": "Normalize upstream version text.",
                                        "type": "boolean"
                                    },
                                    "template": {
                                        "description": "Template mapping upstream version text to PKGBUILD variables.",
                                        "type": "string"
                                    },
                                    "type": {
                                        "type": "string",
                                        "const": "rpm",
                                        "description": "Use an RPM repository."
                                    },
                                    "url": {
                                        "type": "string",
                                        "description": "Repository base URL."
                                    },
                                    "pkg": {
                                        "type": "string",
                                        "description": "RPM package name."
                                    }
                                },
                                "required": [
                                    "type",
                                    "url",
                                    "pkg"
                                ],
                                "additionalProperties": false,
                                "description": "RPM repository version checker."
                            }
                        ],
                        "description": "Upstream version checker."
                    },
                    "builder": {
                        "description": "Build command such as extra-x86_64-build.",
                        "type": "string"
                    },
                    "push": {
                        "description": "Push package PKGBUILD changes to AUR on success.",
                        "type": "boolean"
                    },
                    "dummy_packages": {
                        "description": "Dummy packages installed before build.",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "dummy": {
                                    "type": "string",
                                    "description": "Dummy package name."
                                },
                                "epoch": {
                                    "description": "Dummy package epoch.",
                                    "anyOf": [
                                        {
                                            "type": "string"
                                        },
                                        {
                                            "type": "number"
                                        }
                                    ]
                                },
                                "pkgver": {
                                    "description": "Dummy package version.",
                                    "anyOf": [
                                        {
                                            "type": "string"
                                        },
                                        {
                                            "type": "number"
                                        }
                                    ]
                                },
                                "pkgrel": {
                                    "description": "Dummy package release.",
                                    "anyOf": [
                                        {
                                            "type": "string"
                                        },
                                        {
                                            "type": "number"
                                        }
                                    ]
                                },
                                "files": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    },
                                    "description": "Files provided by the dummy package."
                                }
                            },
                            "required": [
                                "dummy"
                            ],
                            "additionalProperties": false,
                            "description": "A generated dummy dependency package."
                        }
                    },
                    "repo_packages": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Local repo packages required before this build."
                    },
                    "pre-build-packages": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Packages installed in chroot before build."
                    },
                    "pre-build-scripts": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Root scripts run in chroot before build."
                    },
                    "pre_build_packages": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Alias for pre-build-packages."
                    },
                    "pre_build_scripts": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Alias for pre-build-scripts."
                    }
                },
                "required": [
                    "pkgname"
                ],
                "additionalProperties": false,
                "description": "A package build entry."
            },
            "description": "Packages managed by PreAUR."
        }
    },
    "required": [
        "maintainers",
        "packages"
    ],
    "additionalProperties": false,
    "description": "PreAUR configuration file."
}
