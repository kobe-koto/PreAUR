{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "definitions": {
        "PreaurChrootPacmanConfig": {
            "additionalProperties": false,
            "properties": {
                "include": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "lines": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "repositories": {
                    "items": {
                        "$ref": "#/definitions/PreaurChrootPacmanRepository"
                    },
                    "type": "array"
                }
            },
            "type": "object"
        },
        "PreaurChrootPacmanRepository": {
            "additionalProperties": false,
            "properties": {
                "include": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "lines": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "name": {
                    "type": "string"
                },
                "siglevel": {
                    "anyOf": [
                        {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "string"
                        }
                    ]
                }
            },
            "required": [
                "name"
            ],
            "type": "object"
        },
        "PreaurDebChecker": {
            "additionalProperties": false,
            "properties": {
                "arch": {
                    "type": "string"
                },
                "component": {
                    "type": "string"
                },
                "dist": {
                    "type": "string"
                },
                "normalize": {
                    "type": "boolean"
                },
                "pkg": {
                    "type": "string"
                },
                "strip_version": {
                    "type": "boolean"
                },
                "template": {
                    "type": "string"
                },
                "type": {
                    "const": "deb",
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            },
            "required": [
                "component",
                "dist",
                "pkg",
                "type",
                "url"
            ],
            "type": "object"
        },
        "PreaurDummyPackage": {
            "additionalProperties": false,
            "properties": {
                "dummy": {
                    "type": "string"
                },
                "epoch": {
                    "type": [
                        "string",
                        "number"
                    ]
                },
                "files": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "pkgrel": {
                    "type": [
                        "string",
                        "number"
                    ]
                },
                "pkgver": {
                    "type": [
                        "string",
                        "number"
                    ]
                }
            },
            "required": [
                "dummy"
            ],
            "type": "object"
        },
        "PreaurGitHubChecker": {
            "additionalProperties": false,
            "properties": {
                "normalize": {
                    "type": "boolean"
                },
                "prefix": {
                    "type": "string"
                },
                "repo": {
                    "type": "string"
                },
                "strip_version": {
                    "type": "boolean"
                },
                "suffix": {
                    "type": "string"
                },
                "template": {
                    "type": "string"
                },
                "type": {
                    "const": "github",
                    "type": "string"
                },
                "use": {
                    "type": "string"
                }
            },
            "required": [
                "repo",
                "type"
            ],
            "type": "object"
        },
        "PreaurMaintainer": {
            "additionalProperties": false,
            "properties": {
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            },
            "required": [
                "email",
                "id",
                "name"
            ],
            "type": "object"
        },
        "PreaurPackage": {
            "additionalProperties": false,
            "properties": {
                "allow_orphan_package_build": {
                    "type": "boolean"
                },
                "aur_pkgname": {
                    "type": "string"
                },
                "builder": {
                    "type": "string"
                },
                "checker": {
                    "anyOf": [
                        {
                            "$ref": "#/definitions/PreaurGitHubChecker"
                        },
                        {
                            "$ref": "#/definitions/PreaurDebChecker"
                        },
                        {
                            "$ref": "#/definitions/PreaurRpmChecker"
                        }
                    ]
                },
                "dummy_packages": {
                    "items": {
                        "$ref": "#/definitions/PreaurDummyPackage"
                    },
                    "type": "array"
                },
                "git": {
                    "type": "string"
                },
                "maintainer": {
                    "type": "string"
                },
                "pkgname": {
                    "type": "string"
                },
                "pre-build-packages": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "pre-build-scripts": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "pre_build_packages": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "pre_build_scripts": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "push": {
                    "type": "boolean"
                },
                "repo_packages": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "required": [
                "pkgname"
            ],
            "type": "object"
        },
        "PreaurProjectGitConfig": {
            "additionalProperties": false,
            "properties": {
                "branch": {
                    "type": "string"
                },
                "enabled": {
                    "type": "boolean"
                },
                "push": {
                    "$ref": "#/definitions/PreaurProjectGitPushConfig"
                },
                "remote": {
                    "type": "string"
                },
                "sync": {
                    "$ref": "#/definitions/PreaurProjectGitSyncConfig"
                }
            },
            "type": "object"
        },
        "PreaurProjectGitPushConfig": {
            "additionalProperties": false,
            "properties": {
                "force": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "PreaurProjectGitSyncConfig": {
            "additionalProperties": false,
            "properties": {
                "allowRemoteOverwriteLocal": {
                    "type": "boolean"
                },
                "allow_remote_overwrite_local": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "PreaurRepo": {
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string"
                }
            },
            "required": [
                "name"
            ],
            "type": "object"
        },
        "PreaurResources": {
            "additionalProperties": false,
            "properties": {
                "cpu": {
                    "type": "string"
                },
                "parallel": {
                    "type": "number"
                },
                "updateCheckCocurrent": {
                    "type": "number"
                }
            },
            "required": [
                "parallel",
                "updateCheckCocurrent"
            ],
            "type": "object"
        },
        "PreaurRpmChecker": {
            "additionalProperties": false,
            "properties": {
                "normalize": {
                    "type": "boolean"
                },
                "pkg": {
                    "type": "string"
                },
                "strip_version": {
                    "type": "boolean"
                },
                "template": {
                    "type": "string"
                },
                "type": {
                    "const": "rpm",
                    "type": "string"
                },
                "url": {
                    "type": "string"
                }
            },
            "required": [
                "pkg",
                "type",
                "url"
            ],
            "type": "object"
        },
        "PreaurRuntimeConfig": {
            "additionalProperties": false,
            "properties": {
                "chrootPacman": {
                    "$ref": "#/definitions/PreaurChrootPacmanConfig"
                },
                "pkgbuildParser": {
                    "enum": [
                        "makepkg",
                        "native"
                    ],
                    "type": "string"
                },
                "trustedAurGitPrefixes": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "type": "object"
        }
    },
    "properties": {
        "config": {
            "$ref": "#/definitions/PreaurRuntimeConfig"
        },
        "default_maintainer": {
            "type": "string"
        },
        "git": {
            "$ref": "#/definitions/PreaurProjectGitConfig"
        },
        "maintainers": {
            "items": {
                "$ref": "#/definitions/PreaurMaintainer"
            },
            "type": "array"
        },
        "packages": {
            "items": {
                "$ref": "#/definitions/PreaurPackage"
            },
            "type": "array"
        },
        "repo": {
            "$ref": "#/definitions/PreaurRepo"
        },
        "resources": {
            "$ref": "#/definitions/PreaurResources"
        }
    },
    "required": [
        "maintainers",
        "packages",
        "repo",
        "resources"
    ],
    "type": "object"
}

